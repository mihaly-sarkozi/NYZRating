{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Docker: Backend attach (debugpy)",
      "type": "python",
      "request": "attach",
      "host": "localhost",
      "port": 5678,
      "pathMappings": [
        {
          "localRoot": "${workspaceFolder}/backend",
          "remoteRoot": "/app/backend"
        }
      ],
      "justMyCode": false,
      "subProcess": false,
      "redirectOutput": true
    },
    {
      "name": "Docker: Backend attach (debugpy extension)",
      "type": "debugpy",
      "request": "attach",
      "connect": {
        "host": "localhost",
        "port": 5678
      },
      "pathMappings": [
        {
          "localRoot": "${workspaceFolder}/backend",
          "remoteRoot": "/app/backend"
        }
      ],
      "justMyCode": false,
      "subProcess": false,
      "redirectOutput": true
    },
    {
      "name": "Backend: uvicorn (local, no Docker)",
      "type": "python",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "main:app",
        "--reload",
        "--host",
        "0.0.0.0",
        "--port",
        "8010"
      ],
      "cwd": "${workspaceFolder}/backend",
      "justMyCode": false,
      "env": {
        "APP_ENV": "dev"
      }
    }
  ]
}
