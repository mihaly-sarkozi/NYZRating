# Production env sablon — másold .env névre és töltsd ki. Ne commitolj titkokat.
APP_ENV=production
APP_NAME=AIPLAZA
APP_DESCRIPTION=AIPLAZA production
APP_VERSION=1.0.0

API_HOST=0.0.0.0
API_PORT=8001

POSTGRES_DB=aiplaza
POSTGRES_USER=aiplaza
POSTGRES_PASSWORD=
REDIS_PASSWORD=
QDRANT_API_KEY=
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

DATABASE_URL=postgresql+psycopg2://aiplaza:CHANGE_ME@postgres:5432/aiplaza
REDIS_URL=redis://:CHANGE_ME@redis:6379/0
QDRANT_URL=http://qdrant:6333

JWT_SECRET=
JWT_ISSUER=
JWT_AUDIENCE=
FRONTEND_BASE_URL=https://app.example.com
CORS_ORIGINS=https://app.example.com
TRUSTED_HOSTS=api.example.com,app.example.com
TENANT_BASE_DOMAIN=app.example.com
INSTALL_HOST=api.example.com
SINGLE_TENANT_SLUG=demo

SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=

OBJECT_STORAGE_ENABLED=true
OBJECT_STORAGE_PROVIDER=s3_compatible
OBJECT_STORAGE_ENDPOINT=http://minio:9000
OBJECT_STORAGE_BUCKET=aiplaza-prod
OBJECT_STORAGE_ACCESS_KEY=
OBJECT_STORAGE_SECRET_KEY=
OBJECT_STORAGE_SECURE=false

METRICS_ALLOWED_IPS=127.0.0.1
METRICS_ACCESS_TOKEN=

BILLING_PROVIDER=manual
BILLING_MODE=manual
EMBEDDING_PROVIDER=local

CHAT_CONTEXT_RETENTION_DAYS=90
CHAT_TURN_SNAPSHOT_RETENTION_DAYS=90

VITE_API_URL=https://api.example.com/api
