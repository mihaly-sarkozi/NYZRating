# Production env sablon — másold .env névre és töltsd ki. Ne commitolj titkokat.
APP_ENV=production
APP_NAME=NYZRating
APP_DESCRIPTION=NYZRating production
APP_VERSION=1.0.0

API_HOST=0.0.0.0
API_PORT=8001

POSTGRES_DB=nyzrating
POSTGRES_USER=nyzrating
POSTGRES_PASSWORD=
REDIS_PASSWORD=

DATABASE_URL=postgresql+psycopg2://nyzrating:CHANGE_ME@postgres:5432/nyzrating
REDIS_URL=redis://:CHANGE_ME@redis:6379/0

JWT_SECRET=
JWT_ISSUER=
JWT_AUDIENCE=
FRONTEND_BASE_URL=https://www.example.com
CORS_ORIGINS=https://www.example.com
# Tenant subdomainokhoz kötelező a wildcard (pl. *.nyzrating.com), különben Invalid host header.
TRUSTED_HOSTS=example.com,www.example.com,*.example.com
TENANT_BASE_DOMAIN=example.com
INSTALL_HOST=www.example.com
# Éles HTTPS: ne állítsd FRONTEND_SET_PASSWORD_PORT-ot (vagy hagyd üresen).
# Confirm-signup linkekhez (email megerősítés) a FRONTEND_BASE_URL / INSTALL_HOST kell.
SINGLE_TENANT_SLUG=demo

SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=

# Object storage / Qdrant / chat LLM jelenleg nincs használatban.
OBJECT_STORAGE_ENABLED=false

METRICS_ALLOWED_IPS=127.0.0.1
METRICS_ACCESS_TOKEN=

BILLING_PROVIDER=manual
BILLING_MODE=manual

VITE_API_URL=/api
# Cloudflare Turnstile (nyilvános site key) — frontend build ARG; rebuild kell a változáshoz.
VITE_TURNSTILE_SITE_KEY=
# Backend captcha (secret soha ne menjen a frontendbe)
DEMO_SIGNUP_REQUIRE_CAPTCHA=true
DEMO_SIGNUP_CAPTCHA_PROVIDER=turnstile
DEMO_SIGNUP_CAPTCHA_SECRET=

# Turnstile widget CSP (script + frame + connect)
SECURITY_CSP_EXTRA_SCRIPT_SRC=https://challenges.cloudflare.com
SECURITY_CSP_EXTRA_FRAME_SRC=https://challenges.cloudflare.com
SECURITY_CSP_EXTRA_CONNECT_SRC=https://challenges.cloudflare.com

PLATFORM_ADMIN_BOOTSTRAP_EMAIL=
PLATFORM_ADMIN_BOOTSTRAP_PASSWORD=
PLATFORM_ADMIN_MFA_REQUIRED=true
PLATFORM_ADMIN_ALLOWED_IPS=
